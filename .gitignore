# Generated by XcodeGen — regenerate with `xcodegen generate`, never commit.
*.xcodeproj

# Build products / caches
DerivedData/
.build/
.spm-packages/
Results/
*.xcresult

# Xcode user state
xcuserdata/

# macOS noise
.DS_Store

# fastlane transient output
fastlane/report.xml
fastlane/README.md

# Secrets — NEVER commit. Mirrors the GitHub Actions secrets/variables.
secret.yml
secrets.yml
*.p8
AuthKey_*.p8
*-secrets.md

# CodeGraph index — machine-local, never committed
.codegraph/
