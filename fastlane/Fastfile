# E0.1 TestFlight lane — DORMANT until Gate G0 (rename) clears.
#
# Operator checklist to activate (all operator-owned; agents must not do these):
#   1. Close Gate G0: clear the new name (App Store search / USPTO / domains).
#   2. Create bundle ID + App Group ID + CloudKit container under the NEW name
#      (architecture naming note), then sweep the placeholders per project.yml.
#   3. Create the App Store Connect app + an ASC API key; set up a fastlane match
#      certificates repo.
#   4. Provision GitHub secrets: ASC_API_KEY_P8_BASE64, ASC_KEY_ID, ASC_ISSUER_ID,
#      MATCH_GIT_URL, MATCH_PASSWORD. CI activates automatically on the next merge.
#
# fastlane is preinstalled on GitHub macOS runners; no Gemfile needed at skeleton
# stage (pin one when the lane goes live).

default_platform(:ios)

platform :ios do
  desc "Build, sign (match), and upload an internal TestFlight build"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_API_KEY_P8_BASE64"),
      is_key_content_base64: true
    )

    # One-shot bootstrap: set repo Variable MATCH_BOOTSTRAP=true for the FIRST run only,
    # so match CREATES the distribution cert + App Store profiles and pushes them
    # (encrypted) to MATCH_GIT_URL. Delete that Variable afterwards — CI must stay
    # read-only so a routine build never mutates the signing repo.
    match(
      type: "appstore",
      readonly: ENV["MATCH_BOOTSTRAP"] != "true",
      app_identifier: ["com.beyondkaira.ballast", "com.beyondkaira.ballast.widgets"],
      git_url: ENV.fetch("MATCH_GIT_URL"),
      api_key: api_key
    )

    # Map the match-minted App Store profiles onto BOTH targets for the archive.
    # project.yml ships CODE_SIGN_STYLE: Automatic and CI has no Xcode-managed Apple ID,
    # so without this gym fails with "No profiles for 'com.beyondkaira.ballast' were
    # found … Automatic signing is disabled" (Session 06 fix; see resume-prompt Step 0).
    # match exposes each minted profile's name as sigh_<bundle_id>_appstore_profile-name.
    app_profile = ENV.fetch("sigh_com.beyondkaira.ballast_appstore_profile-name")
    widget_profile = ENV.fetch("sigh_com.beyondkaira.ballast.widgets_appstore_profile-name")

    update_code_signing_settings(
      path: "Unhooked.xcodeproj",
      targets: ["Unhooked"],
      use_automatic_signing: false,
      team_id: "UH7MXG7Z94",
      code_sign_identity: "Apple Distribution",
      profile_name: app_profile
    )
    update_code_signing_settings(
      path: "Unhooked.xcodeproj",
      targets: ["UnhookedWidgets"],
      use_automatic_signing: false,
      team_id: "UH7MXG7Z94",
      code_sign_identity: "Apple Distribution",
      profile_name: widget_profile
    )

    # E0.1 acceptance: build number auto-increments — monotonic per CI run.
    build_number = ENV.fetch("GITHUB_RUN_NUMBER")

    gym(
      project: "Unhooked.xcodeproj",
      scheme: "Unhooked",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.beyondkaira.ballast" => app_profile,
          "com.beyondkaira.ballast.widgets" => widget_profile,
        },
      },
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}"
    )

    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
